# For running from source (`npm start` / `npm run dev`), which loads this file.
# The Docker path does NOT read this — set the compose variables (CONFIG_PATH,
# DATA_PATH, CSRF_SECRET, ...) in a .env next to docker-compose.yml instead; see
# docker-compose.example.yml.

TZ=Australia/Sydney
PUID=1000
PGID=1000

# 32+ random bytes (e.g. `openssl rand -hex 32`). Used to sign the CSRF cookie.
CSRF_SECRET=

# Optional. Container path to Plex's Preferences.xml. Only relevant if you mount
# Plex's config into the container so the "Auto-detect from local Plex" Settings
# button can fish out PlexOnlineToken. Leave blank (and skip the bind-mount in
# docker-compose) if Plex doesn't run on this host — the button degrades gracefully.
# PLEX_PREFS_PATH=/plex-preferences.xml
