{
  "name": "fetcharr",
  "version": "1.3.1",
  "author": "James Furey (https://about.me/jamesfurey)",
  "description": "Fetch TV → Plex bridge",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/furey/fetcharr.git"
  },
  "homepage": "https://furey.github.io/fetcharr/",
  "keywords": [
    "plex",
    "fetch-tv",
    "fetchtv",
    "dvr",
    "pvr",
    "recordings",
    "media-server",
    "self-hosted",
    "docker",
    "arr",
    "plex-media-server"
  ],
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=11.10.0"
  },
  "volta": {
    "node": "22.19.0",
    "npm": "11.15.0"
  },
  "overrides": {
    "qs": "^6.15.2"
  },
  "scripts": {
    "setup": "npm ci --ignore-scripts && npm run rebuild:natives && npm audit signatures",
    "rebuild:natives": "npm rebuild --ignore-scripts=false better-sqlite3",
    "migrate": "mkdir -p config && knex migrate:latest",
    "migrate:refresh": "rm -f ./config/state.db && mkdir -p config && knex migrate:latest",
    "prestart": "npm run migrate",
    "start": "node --env-file-if-exists=.env src/server.js",
    "predev": "npm run migrate",
    "dev": "node --env-file-if-exists=.env --watch src/server.js",
    "test": "node --test 'test/*.test.js'"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "better-sqlite3": "^11.5.0",
    "cookie-parser": "^1.4.7",
    "csrf-csrf": "^3.0.6",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "fast-xml-parser": "^4.5.5",
    "fetchtv": "1.8.2",
    "fuse.js": "^7.0.0",
    "helmet": "^8.0.0",
    "knex": "^3.1.0",
    "node-cron": "^4.2.1",
    "pretty-ms": "^9.0.0",
    "vue": "^3.5.13",
    "ws": "8.21.0"
  }
}
